# ============================================================
# Legere SaaS — Variáveis de Ambiente
# ============================================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha cada valor abaixo com suas próprias credenciais
# 3. NUNCA commite o arquivo .env no Git!
#
# Para Vercel: configure em Settings → Environment Variables
# ============================================================

# Google Gemini AI (requerido para IA Jurídica — planos Profissional/Enterprise)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# Supabase (requerido para todos os planos)
# Obtenha em: https://supabase.com/dashboard/project/<seu-projeto>/settings/api-keys
VITE_SUPABASE_URL=https://<seu-projeto>.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui
